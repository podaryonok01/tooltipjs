{
  "name": "ui-tooltipjs",
  "version": "1.1.0",
  "description": "",
  "type": "module",
  "main": "dist/index.cjs.js",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.esm.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.esm.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs.js"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "private": false,
  "keywords": [
    "tooltip"
  ],
  "scripts": {
    "test": "jest",
    "build": "pnpm run build:parallel",
    "clean": "rimraf lib",
    "build:parallel": "pnpm run clean && concurrently 'pnpm run build:js' 'pnpm run build:types'",
    "build:types": "tsc --emitDeclarationOnly",
    "build:js": "rollup -c",
    "prepare": "npm run build",
    "watch-tsc": "tsc -w",
    "prettier": "npx prettier --write src/* test/* example/*",
    "tslint": "tslint -p tslint -p tsconfig.json",
    "codestyle": "npm run prettier && npm run tslint"
  },
  "author": "Darya Melnikova",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/podaryonok01/tooltipjs"
  },
  "homepage": "https://github.com/podaryonok01/tooltipjs#readme",
  "bugs": "https://github.com/podaryonok01/tooltipjs/issues",
  "license": "MIT",
  "devDependencies": {
    "rollup-plugin-styles": "^4.0.0",
    "rimraf": "^4.4.1",
    "concurrently": "^9.2.1",
    "rollup": "^4.52.5",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-typescript": "^12.1.4",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "rollup-plugin-tsconfig-paths": "^1.5.2",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-typescript": "^12.1.4",
    "rollup-plugin-typescript-paths": "^1.5.0",
    "@babel/core": "7.18.5",
    "@babel/plugin-proposal-class-properties": "7.17.12",
    "@babel/plugin-proposal-object-rest-spread": "7.18.0",
    "@babel/preset-env": "7.18.2",
    "@babel/preset-typescript": "7.17.12",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "sass": "1.49.9",
    "ts-jest": "^29.1.2",
    "tslint": "^6.1.3",
    "tslint-config-prettier": "^1.18.0",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist"
  ]
}
